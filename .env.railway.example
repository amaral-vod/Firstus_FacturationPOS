# Variables Railway — copier dans le service Web (Settings → Variables)
# Références Postgres : remplacez Postgres par le nom de votre service BDD

APP_NAME="Firstus FacturationPOS"
APP_ENV=staging
APP_DEBUG=false
APP_DEMO_MODE=true
APP_URL=https://VOTRE-APP.up.railway.app

# Générer en local : php artisan key:generate --show
APP_KEY=base64:VOTRE_CLE_ICI

DB_CONNECTION=mysql
DB_URL=${{MySQL.DATABASE_URL}}

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

RUN_SEEDERS=true

LOG_CHANNEL=stderr
